@model SV22T1020459.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-info">
    <strong class="modal-title">
        Chọn người giao hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Shipping/@Model.OrderID" method="post">
    <div class="modal-body">
        <div class="row">
            <div class="col-12">
                <label class="form-label fw-bold">Người giao hàng</label>
                <select class="form-select" name="shipperID" asp-items="await SelectListHelper.Shippers()" required></select>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle"></i> Giao hàng
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>