@model PagedResult<Product>
@{
    Layout = null;
}

@foreach (var item in Model.DataItems)
{
    <form onsubmit="addCartItem(event,this)" class="border rounded p-2 mb-3">

        <input type="hidden" name="productID" value="@item.ProductID" />

        <strong>@item.ProductName</strong>

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                     class="img-thumbnail"
                     style="width: 80px; height: 80px; object-fit: cover;"
                     onerror="this.onerror=null;this.src='/images/products/nophoto.png';"
                     alt="Ảnh" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Gia</label>
                        <input class="form-control form-control-sm money-input" name="price"
                               value="@item.Price" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number" name="quantity"
                               min="1"
                               value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}
<ul class="pagination justify-content-between mb-0">
    <li class="page-item">
        <a class="page-link" href="javascript:;"
           onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
            <
        </a>
    </li>
    <li class="page-item">
        <a class="page-link" href="javascript:;"
           onclick="paginationSearch(event, document.getElementById('formSearch'),@(Model.Page + 1))">
            >
        </a>
    </li>
</ul>