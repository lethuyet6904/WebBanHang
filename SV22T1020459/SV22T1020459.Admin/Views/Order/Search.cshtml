@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th>Tổng tiền</th>
                    <th style="width:180px;">Trạng thái</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@item.CustomerName</td>

                        <td class="text-center">@item.CustomerPhone</td>

                        <td class="text-center">
                            @(item.AcceptTime.HasValue? item.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm") : "")
                        </td>

                        <td>@(string.IsNullOrEmpty(item.EmployeeName) ? "Chưa phân công" : item.EmployeeName)</td>

                        <td class="text-end fw-bold text-danger">@item.TotalPrice.ToString("N0") ₫</td>

                        <td class="text-center">
                            @{
                                string badgeClass = "bg-secondary";

                                if (item.Status == OrderStatusEnum.New)
                                {
                                    badgeClass = "bg-info text-dark";
                                }
                                else if (item.Status == OrderStatusEnum.Accepted)
                                {
                                    badgeClass = "bg-primary";
                                }
                                else if (item.Status == OrderStatusEnum.Shipping)
                                {
                                    badgeClass = "bg-warning text-dark";
                                }
                                else if (item.Status == OrderStatusEnum.Completed)
                                {
                                    badgeClass = "bg-success";
                                }
                                else if (item.Status == OrderStatusEnum.Cancelled || item.Status == OrderStatusEnum.Rejected)
                                {
                                    badgeClass = "bg-danger"; 
                                }
                            }

                            <span class="badge @badgeClass fs-6">
                                @item.Status.GetDescription()
                            </span>
                        </td>

                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary" title="Xem chi tiết đơn hàng">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <a class="page-link">...</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>