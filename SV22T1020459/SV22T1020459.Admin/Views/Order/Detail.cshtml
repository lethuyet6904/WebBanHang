@model OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    @if (Model.Status == OrderStatusEnum.New ||
             Model.Status == OrderStatusEnum.Accepted ||
             Model.Status == OrderStatusEnum.Shipping)
    {
        <div class="btn-group">
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }
                else if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }
                else if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
                }
            </ul>
        </div>
    }

    @if (Model.Status != OrderStatusEnum.Shipping &&
             Model.Status != OrderStatusEnum.Completed)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="alert alert-success d-flex align-items-center mb-3">
    <i class="bi bi-check-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Status
        @if (Model.FinishedTime.HasValue)
        {
            <span>lúc <b>@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></span>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-receipt me-2"></i> Thông tin đơn hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.EmployeeName) ? "Chưa có" : Model.EmployeeName)</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa nhận")</div>
        </div>
    </div>
</div>

<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-person me-2"></i> Thông tin khách hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>
    </div>
</div>

<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-truck me-2"></i> Thông tin giao hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.ShipperName) ? "Chưa có" : Model.ShipperName)</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<div id="list-details-container"></div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}

@section Scripts {
    <script>
                document.addEventListener("DOMContentLoaded", function () {
                    loadOrderDetails();
                });

                function loadOrderDetails() {
                    const orderId = '@Model.OrderID';
                    fetch(`/Order/DetailProduct/${orderId}`)
                        .then(response => {
                            if (!response.ok) throw new Error("Lỗi mạng hoặc sai đường dẫn");
                            return response.text();
                        })
                        .then(html => {
                            document.getElementById("list-details-container").innerHTML = html;
                        })
                        .catch(error => {
                            console.error("Có lỗi xảy ra:", error);
                            document.getElementById("list-details-container").innerHTML =
                                '<div class="alert alert-danger">Không thể tải danh sách mặt hàng. Vui lòng thử lại!</div>';
                        });
                }
                        function UpdateDetailData(event, form) {
                    event.preventDefault();
                    const formData = new FormData(form);
                    const actionUrl = form.getAttribute("action");
                    fetch(actionUrl, {
                        method: "POST",
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            const modalElement = document.querySelector('.modal.show');
                            if (modalElement) {
                                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                                if (modalInstance) {
                                    modalInstance.hide();
                                }
                            }

                            loadOrderDetails();

                        } else {
                            alert(data.message || "Có lỗi xảy ra khi cập nhật!");
                        }
                    })
                    .catch(error => {
                        console.error("Lỗi:", error);
                        alert("Không thể kết nối đến máy chủ!");
                    });

                    return false;
                }
                function UpdateDetailData(event, form) {
                    event.preventDefault();

                    const formData = new FormData(form);
                    const actionUrl = form.getAttribute("action");

                    fetch(actionUrl, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 0) {
                            alert(data.message || "Không thể cập nhật. Vui lòng kiểm tra lại!");
                        } else {

                            const modalElement = document.querySelector('.modal.show');
                            if (modalElement) {
                                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                                if (modalInstance) {
                                    modalInstance.hide();
                                }
                            }

                            loadOrderDetails();
                        }
                    })
                    .catch(error => {
                        console.error("Lỗi cập nhật chi tiết:", error);
                        alert("Hệ thống đang bận, vui lòng thử lại sau!");
                    });

                }
                function doDeleteDetail(event, form) {
                    event.preventDefault();

                    const formData = new FormData(form);
                    const actionUrl = form.getAttribute("action");

                    fetch(actionUrl, {
                        method: "POST",
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 1) {
                            const modalElement = document.querySelector('.modal.show');
                            if (modalElement) {
                                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                                if (modalInstance) {
                                    modalInstance.hide();
                                }
                            }

                            loadOrderDetails();

                        } else {
                            alert(data.message || "Không thể xóa mặt hàng này!");
                        }
                    })
                    .catch(error => {
                        console.error("Lỗi xóa chi tiết:", error);
                        alert("Hệ thống đang bận, không thể thực hiện xóa!");
                    });

                    return false;
                }
    </script>
}