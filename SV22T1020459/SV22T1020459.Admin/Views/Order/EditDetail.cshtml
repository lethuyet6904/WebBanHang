@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header bg-primary">
    <h5 class="modal-title text-white">
        Cập nhật chi tiết đơn hàng
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body">
    <form id="formEditDetail" action="~/Order/UpdateDetail" method="post" class="container-fluid" onsubmit="return UpdateDetailData(event, this)">

        <input type="hidden" name="orderId" value="@Model.OrderID" />
        <input type="hidden" name="productId" value="@Model.ProductID" />

        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Mặt hàng
                    </label>
                    <div class="col-sm-8">
                        <input type="text"
                               class="form-control-plaintext fw-bold"
                               value="@Model.ProductName"
                               readonly>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Số lượng
                    </label>
                    <div class="col-sm-5">
                        <input type="number"
                               class="form-control text-end"
                               min="1"
                               name="quantity"
                               value="@Model.Quantity">
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Đơn giá
                    </label>
                    <div class="col-sm-5">
                        <input type="text"
                               class="form-control text-end money-input"
                               name="salePrice"
                               value="@Model.SalePrice.ToString("0")">
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center align-content-center">
                <img src="@(string.IsNullOrEmpty(Model.Photo) ? "/images/products/no-image.png" : $"/images/products/{Model.Photo}")"
                     alt="@Model.ProductName"
                     class="img-thumbnail"
                     style="max-height:150px; object-fit: contain;">
            </div>
        </div>
    </form>
</div>

<div class="modal-footer">
    <button type="submit" class="btn btn-primary" form="formEditDetail">
        <i class="fa fa-save"></i> Cập nhật
    </button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        Đóng
    </button>
</div>