@model Customer
@{
    ViewBag.Title = "Mật khẩu khách hàng";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Lưu mật khẩu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Thành công!</strong> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Lỗi!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Cấp lại mật khẩu khách hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" action="~/Customer/ChangePassword/@Model.CustomerID" method="post">

                    @Html.ValidationSummary(true, "", new { @class = "text-danger fw-bold mb-3" })

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin khách hàng
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Tên khách hàng</dt>
                            <dd class="col-sm-9 fw-bold text-primary">@Model.CustomerName</dd>

                            <dt class="col-sm-3">Email (Tài khoản)</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsLocked)
                                {
                                    <span class="badge bg-danger">Đang bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Đang hoạt động</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-key me-1"></i>
                            Thiết lập mật khẩu mới
                        </legend>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password"
                                   class="form-control"
                                   name="newPassword"
                                   placeholder="Nhập mật khẩu mới" required autofocus />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu</label>
                            <input type="password"
                                   class="form-control"
                                   name="confirmPassword"
                                   placeholder="Nhập lại mật khẩu mới" required />
                        </div>

                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>