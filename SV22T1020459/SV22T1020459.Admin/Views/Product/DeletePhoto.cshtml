@model ProductPhoto
@{
    ViewBag.Title = "Xác nhận xóa ảnh";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="alert alert-danger shadow-sm mt-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-octagon-fill fs-3 me-3"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-1">Xác nhận xóa ảnh!</h5>
                    <p class="mb-0">Bạn có chắc chắn muốn xóa hình ảnh này khỏi thư viện sản phẩm? Hành động này không thể hoàn tác.</p>
                </div>
            </div>
        </div>

        <div class="card card-danger card-outline">
            <div class="card-header">
                <h3 class="card-title m-0">
                    <i class="bi bi-trash3"></i> Thông tin ảnh cần xóa
                </h3>
            </div>

            <div class="card-body">
                <div class="row mb-3 border-bottom pb-3">
                    <label class="col-sm-4 col-form-label text-end text-muted">Hình ảnh:</label>
                    <div class="col-sm-8">
                        <div class="p-2 border rounded bg-light d-inline-block">
                            <img src="~/images/products/@(string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo)" class="img-fluid shadow-sm" style="max-height: 200px; object-fit: contain;" alt="Ảnh cần xóa">
                        </div>
                    </div>
                </div>

                <div class="row mb-3 border-bottom pb-2">
                    <label class="col-sm-4 col-form-label text-end text-muted">Mô tả:</label>
                    <div class="col-sm-8 col-form-label fw-bold text-dark">
                        @Model.Description
                    </div>
                </div>

                <div class="row mb-3 border-bottom pb-2">
                    <label class="col-sm-4 col-form-label text-end text-muted">Thứ tự hiển thị:</label>
                    <div class="col-sm-8 col-form-label text-dark">
                        @Model.DisplayOrder
                    </div>
                </div>
            </div>

            <div class="card-footer text-end bg-light">
                <form action="~/Product/DeletePhoto/@Model.ProductID?photoId=@Model.PhotoID" method="post">

                    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary me-1">
                        <i class="bi bi-arrow-return-left"></i> Quay lại
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i> Xóa vĩnh viễn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>