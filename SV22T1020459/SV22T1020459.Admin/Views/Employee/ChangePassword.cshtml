@model Employee
@{
    ViewBag.Title = "Đổi mật khẩu nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Lưu mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Cấp lại mật khẩu nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" action="~/Employee/ChangePassword/@Model.EmployeeID" method="post">

                    @Html.ValidationSummary(true, "", new { @class = "text-danger fw-bold mb-3" })

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9 fw-bold text-primary">@Model.FullName</dd>

                            <dt class="col-sm-3">Email (Tài khoản)</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-key me-1"></i>
                            Thiết lập mật khẩu mới
                        </legend>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password"
                                   class="form-control"
                                   name="newPassword"
                                   placeholder="Nhập mật khẩu mới" required autofocus />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu</label>
                            <input type="password"
                                   class="form-control"
                                   name="confirmPassword"
                                   placeholder="Nhập lại mật khẩu mới" required />
                        </div>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>