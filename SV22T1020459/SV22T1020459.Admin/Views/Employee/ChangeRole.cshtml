@model Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";

    var currentRoles = string.IsNullOrEmpty(Model.RoleNames)
        ? new List<string>()
        : Model.RoleNames.Split(',').Select(r => r.Trim()).ToList();
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" action="~/Employee/ChangeRole/@Model.EmployeeID" method="post">

                    @Html.ValidationSummary(true, "", new { @class = "text-danger fw-bold mb-3" })

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i> Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9 fw-bold text-primary">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i> Danh sách quyền
                        </legend>

                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:60px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="selectedRoles" value="@WebUserRoles.DataManager"
                                                   @(currentRoles.Contains(WebUserRoles.DataManager) ? "checked" : "") />
                                        </td>
                                        <td>Quản lý dữ liệu</td>
                                        <td>Thêm, sửa, xóa thông tin khách hàng, nhà cung cấp, mặt hàng...</td>
                                    </tr>

                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="selectedRoles" value="@WebUserRoles.Sales"
                                                   @(currentRoles.Contains(WebUserRoles.Sales) ? "checked" : "") />
                                        </td>
                                        <td>Quản lý bán hàng</td>
                                        <td>Tạo, xử lý, theo dõi trạng thái đơn hàng</td>
                                    </tr>

                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="selectedRoles" value="@WebUserRoles.Administrator"
                                                   @(currentRoles.Contains(WebUserRoles.Administrator) ? "checked" : "") />
                                        </td>
                                        <td class="text-danger fw-bold">Quản trị hệ thống</td>
                                        <td>Quản lý nhân viên, phân quyền, cấu hình hệ thống</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>