@model ChangePassword
@using SV22T1020459.Shop
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-5 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AccountSidebar")
        </div>

        <div class="col-md-9">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <div class="page-card">
                <div class="page-card__header">
                    <h5><i class="bi bi-shield-lock me-2"></i>Thay đổi mật khẩu</h5>
                    <p class="text-muted small mb-0 mt-1">Vui lòng nhập mật khẩu cũ và mật khẩu mới để bảo mật tài khoản.</p>
                </div>
                <div class="card-body p-4">
                    <form action="/User/ChangePassword" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
                            <div class="auth-input-group">
                                <i class="bi bi-key-fill auth-input-icon"></i>
                                <input type="password" id="oldPw" name="oldPassword" class="auth-input" placeholder="Nhập mật khẩu cũ..." required>
                                <button type="button" class="auth-input-toggle" onclick="togglePw('oldPw','eye1')">
                                    <i class="bi bi-eye" id="eye1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Mật khẩu mới</label>
                            <div class="auth-input-group">
                                <i class="bi bi-lock-fill auth-input-icon"></i>
                                <input type="password" id="newPw" name="newPassword" class="auth-input" placeholder="Ít nhất 6 ký tự..." required>
                                <button type="button" class="auth-input-toggle" onclick="togglePw('newPw','eye2')">
                                    <i class="bi bi-eye" id="eye2"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                            <div class="auth-input-group">
                                <i class="bi bi-shield-check auth-input-icon"></i>
                                <input type="password" id="confirmPw" name="confirmPassword" class="auth-input" placeholder="Nhập lại mật khẩu mới..." required>
                                <button type="button" class="auth-input-toggle" onclick="togglePw('confirmPw','eye3')">
                                    <i class="bi bi-eye" id="eye3"></i>
                                </button>
                            </div>
                        </div>

                        <div class="pw-tips mb-4">
                            <div class="pw-tip"><i class="bi bi-check-circle text-success me-2"></i>Ít nhất 6 ký tự</div>
                            <div class="pw-tip"><i class="bi bi-check-circle text-success me-2"></i>Nên kết hợp chữ và số</div>
                            <div class="pw-tip"><i class="bi bi-check-circle text-success me-2"></i>Không dùng thông tin cá nhân</div>
                        </div>

                        <button type="submit" class="btn btn-green btn-lg fw-bold w-100 py-3 rounded-3">
                            <i class="bi bi-save me-2"></i>CẬP NHẬT MẬT KHẨU
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePw(inputId, iconId) {
        const inp = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        inp.type = inp.type === 'password' ? 'text' : 'password';
        icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    }
</script>