@model Customer
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – @ApplicationContext.AppName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="auth-page">

    <div class="auth-split-layout">
        <!-- LEFT PANEL -->
        <div class="auth-split-left">
            <div class="auth-split-left__content">
                <div class="auth-brand">
                    <div class="auth-brand__icon"><i class="bi bi-bag-heart-fill"></i></div>
                    <span class="auth-brand__name">@ApplicationContext.AppName</span>
                </div>
                <h1 class="auth-split-title">Tạo tài khoản mới!</h1>
                <p class="auth-split-desc">Đăng ký để bắt đầu mua sắm thông minh, nhận ưu đãi độc quyền và theo dõi đơn hàng dễ dàng.</p>
                <div class="auth-features">
                    <div class="auth-feature-item">
                        <i class="bi bi-gift-fill"></i>
                        <span>Ưu đãi dành riêng cho thành viên</span>
                    </div>
                    <div class="auth-feature-item">
                        <i class="bi bi-truck"></i>
                        <span>Giao hàng toàn quốc nhanh chóng</span>
                    </div>
                    <div class="auth-feature-item">
                        <i class="bi bi-arrow-repeat"></i>
                        <span>Đổi trả dễ dàng trong 7 ngày</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="auth-split-right" style="overflow-y: auto; padding: 2rem 0;">
            <div class="auth-form-wrap" style="max-width: 520px;">
                <div class="text-center mb-4">
                    <h3 class="fw-bold" style="color:var(--green-darker);">Đăng ký tài khoản</h3>
                    <p class="text-muted small">Điền thông tin để tạo tài khoản mới</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @Html.ValidationSummary(false, "", new { @class = "mb-0 small list-unstyled mt-1" })
                    </div>
                }

                <form action="/User/Register" method="post">

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-semibold small">Tên khách hàng <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-person-fill auth-input-icon"></i>
                                <input type="text" name="CustomerName" class="auth-input"
                                       placeholder="Nhập tên..." value="@Model?.CustomerName" required autofocus>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Tên liên hệ <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-person-lines-fill auth-input-icon"></i>
                                <input type="text" name="ContactName" class="auth-input"
                                       placeholder="Tên người đại diện..." value="@Model?.ContactName" required>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-semibold small">Email đăng nhập <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-envelope-fill auth-input-icon"></i>
                                <input type="email" name="Email" class="auth-input"
                                       placeholder="example@gmail.com" value="@Model?.Email" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Số điện thoại <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-phone-fill auth-input-icon"></i>
                                <input type="text" name="Phone" class="auth-input"
                                       placeholder="0xxx xxx xxx" value="@Model?.Phone" required>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-semibold small">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                            <div class="auth-input-group" style="padding:0;">
                                <select class="auth-input" name="Province" required
                                        asp-items="await SelectListHelper.Provinces()"
                                        style="padding-left: 1rem;">
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Địa chỉ chi tiết</label>
                            <div class="auth-input-group">
                                <i class="bi bi-geo-alt-fill auth-input-icon"></i>
                                <input type="text" name="Address" class="auth-input"
                                       placeholder="Số nhà, đường, phường/xã..." value="@Model?.Address">
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-semibold small">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-lock-fill auth-input-icon"></i>
                                <input type="password" name="Password" id="passwordInput" class="auth-input"
                                       placeholder="Ít nhất 6 ký tự..." required>
                                <button type="button" class="auth-input-toggle" onclick="togglePassword('passwordInput','eyeIcon1')">
                                    <i class="bi bi-eye" id="eyeIcon1"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <div class="auth-input-group">
                                <i class="bi bi-shield-lock-fill auth-input-icon"></i>
                                <input type="password" name="ConfirmPassword" id="confirmInput" class="auth-input"
                                       placeholder="Nhập lại mật khẩu..." required>
                                <button type="button" class="auth-input-toggle" onclick="togglePassword('confirmInput','eyeIcon2')">
                                    <i class="bi bi-eye" id="eyeIcon2"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-green w-100 py-3 mb-3 fw-bold fs-6 rounded-3">
                        <i class="bi bi-person-plus me-2"></i>HOÀN TẤT ĐĂNG KÝ
                    </button>

                    <div class="auth-divider"><span>hoặc</span></div>

                    <p class="text-center small text-muted mb-0 mt-3">
                        Đã có tài khoản?
                        <a href="/User/Login" class="fw-bold ms-1" style="color:var(--green);">Đăng nhập tại đây</a>
                    </p>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                inp.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
</body>
</html>
