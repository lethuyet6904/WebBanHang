@model PagedResult<Product>
@{
    Layout = null;
}

<div class="container mb-5">
    <div class="d-flex align-items-center mb-4 mt-2">
        <span class="result-count-badge">@Model.RowCount sản phẩm</span>
    </div>

    @if (!Model.DataItems.Any())
    {
        <div class="empty-msg">
            <i class="bi bi-box-seam"></i>
            <p>Không tìm thấy sản phẩm phù hợp</p>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 mb-5">
            @foreach (var item in Model.DataItems)
            {
                <div class="col">
                    <div class="pcard">
                        @if (item.Price == 0)
                        {
                            <div class="pcard__badge pcard__badge--out">Hết hàng</div>
                        }
                        <a href="/Product/Detail/@item.ProductID" class="pcard__img-wrap">
                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                 class="pcard__img"
                                 alt="@item.ProductName"
                                 onerror="this.onerror=null;this.src='/images/products/nophoto.png';" />
                        </a>
                        <div class="pcard__body">
                            <a href="/Product/Detail/@item.ProductID" class="pcard__name">@item.ProductName</a>
                            <div class="pcard__footer">
                                <span class="pcard__price">@string.Format("{0:N0} ₫", item.Price)</span>
                            </div>
                            <form class="ajax-add-to-cart" action="/Cart/Add" method="post">
                                <input type="hidden" name="productId" value="@item.ProductID" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="pcard__add-btn">
                                    <i class="bi bi-cart-plus-fill me-2"></i>Thêm vào giỏ
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (Model.PageCount > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsCurrent)
                    {
                        <li class="page-item active"><a class="page-link">@p.Page</a></li>
                    }
                    else if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><a class="page-link">…</a></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }
            </ul>
        </nav>
    }
</div>
